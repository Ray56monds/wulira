# Wulira Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# CORS Settings (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Job Settings
MAX_JOBS_IN_MEMORY=100
JOB_TIMEOUT_SECONDS=3600
JOB_CLEANUP_INTERVAL_SECONDS=300
MAX_VIDEO_DURATION_SECONDS=7200

# Whisper Model Settings
DEFAULT_WHISPER_MODEL=base
ALLOWED_WHISPER_MODELS=tiny,base,small,medium,large

# Logging
LOG_LEVEL=INFO

# Lyrics Pipeline — Genius API (free token at https://genius.com/api-clients)
GENIUS_API_TOKEN=

# Persistent Storage — Redis (leave empty for in-memory)
# REDIS_URL=redis://localhost:6379/0

# Authentication — set to enable API key auth (leave empty to disable)
# WULIRA_API_KEY=your_master_key_here
